# ──────────────────────────────────────────────────────────────────────────────
# AI Provider — set ONE of the blocks below (first matching key wins)
# ──────────────────────────────────────────────────────────────────────────────

# Google Gemini (highest priority)
# GEMINI_API_KEY=your-gemini-api-key-here
# GEMINI_MODEL=gemini-2.0-flash-lite           # optional, this is the default

# Azure AI Foundry / Azure OpenAI (second priority)
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
# AZURE_OPENAI_API_KEY=your-azure-api-key-here
# AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini          # optional, this is the default
# AZURE_OPENAI_API_VERSION=2024-12-01-preview  # optional

# OpenAI or OpenAI-compatible endpoint (third priority)
# OPENAI_API_KEY=your-openai-api-key-here
# OPENAI_MODEL=gpt-4o-mini                     # optional, this is the default
# OPENAI_BASE_URL=https://your-custom-endpoint # optional (for compatible APIs)

# Anthropic Claude (fallback)
# ANTHROPIC_API_KEY=your-anthropic-api-key-here
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001    # optional, this is the default

# ──────────────────────────────────────────────────────────────────────────────
# Huntr — ONLY needed if you are NOT using huntr-cli.
# If you have huntr-cli installed and have run `huntr login`, credentials
# are picked up automatically from ~/.huntr/config.json or the system keychain.
# ──────────────────────────────────────────────────────────────────────────────
# HUNTR_API_TOKEN=your-huntr-personal-token-here

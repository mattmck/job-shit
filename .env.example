# Anthropic API key (required for tailoring)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Anthropic model to use (optional, defaults to claude-sonnet-4-5)
ANTHROPIC_MODEL=claude-sonnet-4-5

# Huntr API token — ONLY needed if you are NOT using huntr-cli.
# If you have huntr-cli installed and have run `huntr login`, credentials
# are picked up automatically from ~/.huntr/config.json or the system keychain.
# You can also set the same env var that huntr-cli uses:
# HUNTR_API_TOKEN=your-huntr-personal-token-here
